# ==============================================================
# CONFIGURACIÓN DEL ENTORNO LOCAL (Backend)
# Copia este archivo como .env y ajusta los valores necesarios
# ==============================================================

# Entorno y Servidor
NODE_ENV=development
PORT=4000
TZ=America/Guatemala
APP_TIMEZONE=America/Guatemala
LOG_LEVEL=info

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appIncendios2
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_SSL=false

# Seguridad (JWT)
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=2h
JWT_ISSUER=app-incendios
JWT_AUDIENCE=usuarios-app

# CORS y Seguridad Web
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://127.0.0.1:8081

# Redis (Caché y Colas)
REDIS_URL=redis://localhost:6379

# NASA FIRMS (Integración de puntos de calor)
FIRMS_ENABLED=true
FIRMS_API_KEY=tu_api_key_de_nasa_aqui
FIRMS_COUNTRY=GTM
FIRMS_DAYS=3
FIRMS_FETCH_CRON=0 */2 * * *

# INAB (Sincronización automática con ArcGIS del INAB)
INAB_FETCH_CRON=0 6-18 * * *

# Almacenamiento de Medios (Fotos/Videos)
# Deja comentado para usar localhost:4000 por defecto
# MEDIA_BASE_URL=http://localhost:4000
